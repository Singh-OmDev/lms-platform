datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  password       String
  role           String          @default("user") // "user" or "admin"
  createdAt      DateTime        @default(now())
  
  progress       WatchProgress[]
  bookmarks      Bookmarks[]
  comments       Comments[]
  articles       Article[]
  submissions    TestSubmission[]
}

model Video {
  id             Int             @id @default(autoincrement())
  title          String
  description    String
  category       String
  videoUrl       String
  thumbnailUrl   String
  duration       Int             // in seconds
  difficulty     String          @default("Beginner") // "Beginner", "Intermediate", "Advanced"
  estimatedTime  String          @default("10 mins")
  tags           String          @default("") // Comma-separated tags
  createdAt      DateTime        @default(now())
  
  progress       WatchProgress[]
  bookmarks      Bookmarks[]
  comments       Comments[]
}

model WatchProgress {
  id                   Int      @id @default(autoincrement())
  userId               Int
  videoId              Int
  currentTime          Float    @default(0.0) // seconds watch time
  completionPercentage Float    @default(0.0)
  completed            Boolean  @default(false)
  updatedAt            DateTime @updatedAt
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video                Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Bookmarks {
  id        Int      @id @default(autoincrement())
  userId    Int
  videoId   Int
  timestamp Float    // in seconds
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Comments {
  id        Int      @id @default(autoincrement())
  userId    Int
  videoId   Int
  message   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  summary     String
  category    String   // "AI", "Cybersecurity", "General"
  imageUrl    String?
  published   Boolean  @default(true)
  authorId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Test {
  id          Int              @id @default(autoincrement())
  category    String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  questions   Question[]
  submissions TestSubmission[]
}

model Question {
  id             Int      @id @default(autoincrement())
  testId         Int
  type           String   // "MCQ" or "SHORT"
  questionText   String
  options        String   @default("") // Semicolon-separated options for MCQ
  correctOption  String   @default("") // Correct option index or text for MCQ
  createdAt      DateTime @default(now())
  
  test           Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model TestSubmission {
  id        Int      @id @default(autoincrement())
  testId    Int
  userId    Int
  answers   String   // JSON string of answers
  score     Int?
  passed    Boolean  @default(false)
  status    String   @default("pending") // "pending", "graded"
  feedback  String?
  gradedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, testId])
}
